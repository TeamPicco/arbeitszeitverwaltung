SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anwendungs-Konfiguration
APP_TITLE=Arbeitszeitverwaltung
APP_ICON=⏰
