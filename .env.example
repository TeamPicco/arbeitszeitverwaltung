# Bundesland für Feiertags-Berechnung (optional)
# Optionen: BW, BY, BE, BB, HB, HH, HE, MV, NI, NW, RP, SL, SN, ST, SH, TH
# Default für dieses Projekt: Sachsen (SN)
BUNDESLAND=SN

# Session-Konfiguration
SESSION_TIMEOUT_MINUTES=480

# Dokument-Verschlüsselung (PFLICHT für Produktion)
# Schlüssel generieren: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
DOCUMENT_ENCRYPTION_KEY=HIER_GENERIERTEN_KEY_EINTRAGEN

# Anthropic API (für KI-Gefährdungsbeurteilung)
ANTHROPIC_API_KEY=sk-ant-HIER_KEY_EINTRAGEN
